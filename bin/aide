#!/usr/bin/env bash
set -euo pipefail

# ── Resolve AIDE_ROOT (follow symlinks to find repo root) ────────────────────
SOURCE="${BASH_SOURCE[0]}"
while [[ -L "$SOURCE" ]]; do
  DIR=$(cd -P "$(dirname "$SOURCE")" && pwd)
  SOURCE=$(readlink "$SOURCE")
  [[ "$SOURCE" != /* ]] && SOURCE="$DIR/$SOURCE"
done
AIDE_ROOT=$(cd -P "$(dirname "$SOURCE")/.." && pwd)

IMAGE_NAME="aide:latest"

# ── Helper functions ─────────────────────────────────────────────────────────

usage() {
  cat <<'EOF'
aide — Claude Code in a secure container

Usage:
  aide                      Launch Claude Code interactively in $PWD
  aide build                Build the aide Docker image
  aide pull                 Update aide (git pull + rebuild)
  aide shell                Drop into a bash shell in the container (for debugging)
  aide -m <path>            Mount path read-only at /extra/<basename>
  aide -mw <path>           Mount path read-write at /extra/<basename>
  aide -p "prompt"          Non-interactive mode (auto-accepts permissions)
  aide --caffeinate|-c      Prevent machine sleep during run (macOS)
  aide --dangerous|-d       Skip all permission prompts (dangerously-skip-permissions)
  aide --docker [rancher|path]  Mount Docker socket (rancher = ~/.rd/docker.sock)
  aide --kube <path>            Mount kubeconfig read-only; auto-detects local clusters
  aide --config <path>          Load project config from path (default: $CWD/aide.yaml)
  aide -- <flags>           Pass extra flags to docker run

Environment:
  AIDE_EXTRA_DOMAINS        Optional. Space-separated FQDNs to allow through firewall.
                            Also merged from firewall-domains.local.txt (gitignored) if present.

Config files (auto-loaded from current directory):
  aide.yaml             Project config (commit this)
  aide.local.yaml       Per-engineer overrides (add to .gitignore)

Config file schema:
  docker: rancher             # or /path/to/docker.sock
  kube: ~/.kube/config        # path to kubeconfig
  extra_domains:              # appended to firewall allowlist
    - registry.example.com
EOF
}

die() {
  echo "aide: error: $*" >&2
  exit 1
}

# ── Config file parsing ───────────────────────────────────────────────────────

# parse_aide_config <file> <output-var-prefix>
# Reads aide.yaml subset into variables:
#   <prefix>_docker, <prefix>_kube, <prefix>_extra_domains (space-separated)
parse_aide_config() {
  local file="$1"
  local prefix="$2"
  local in_domains=false
  local docker_val="" kube_val="" domains_val=""

  while IFS= read -r line || [[ -n "$line" ]]; do
    # Skip comments and blank lines
    [[ "$line" =~ ^[[:space:]]*# ]] && continue
    [[ -z "${line// }" ]] && continue

    if [[ "$line" =~ ^docker:[[:space:]]*(.+)$ ]]; then
      docker_val="${BASH_REMATCH[1]}"
      in_domains=false
    elif [[ "$line" =~ ^kube:[[:space:]]*(.+)$ ]]; then
      kube_val="${BASH_REMATCH[1]}"
      # Expand ~ manually (bash won't expand in variable assignment)
      kube_val="${kube_val/#\~/$HOME}"
      in_domains=false
    elif [[ "$line" =~ ^extra_domains:[[:space:]]*$ ]]; then
      in_domains=true
    elif [[ "$in_domains" == true && "$line" =~ ^[[:space:]]+-[[:space:]]*(.+)$ ]]; then
      local domain="${BASH_REMATCH[1]}"
      domains_val="${domains_val:+$domains_val }$domain"
    else
      in_domains=false
    fi
  done < "$file"

  # Export into named variables using indirect assignment
  printf -v "${prefix}_docker"       '%s' "$docker_val"
  printf -v "${prefix}_kube"         '%s' "$kube_val"
  printf -v "${prefix}_extra_domains" '%s' "$domains_val"
}

# load_project_config <override-config-path>
# Populates CONF_DOCKER, CONF_KUBE, CONF_EXTRA_DOMAINS from aide.yaml + aide.local.yaml
load_project_config() {
  local config_override="${1:-}"
  CONF_DOCKER="" CONF_KUBE="" CONF_EXTRA_DOMAINS=""

  local base_file
  if [[ -n "$config_override" ]]; then
    [[ -f "$config_override" ]] || die "--config: file not found: $config_override"
    base_file="$config_override"
  else
    base_file="$PWD/aide.yaml"
  fi

  if [[ -f "$base_file" ]]; then
    parse_aide_config "$base_file" "_base"
    CONF_DOCKER="$_base_docker"
    CONF_KUBE="$_base_kube"
    CONF_EXTRA_DOMAINS="$_base_extra_domains"
  fi

  # Local overrides (only when using auto-discovery, not --config)
  local local_file="$PWD/aide.local.yaml"
  if [[ -z "$config_override" && -f "$local_file" ]]; then
    # Warn if aide.local.yaml is not gitignored
    if [[ -f "$PWD/.gitignore" ]] && ! grep -qxF 'aide.local.yaml' "$PWD/.gitignore" 2>/dev/null; then
      echo "aide: warning: aide.local.yaml found but not in .gitignore — consider adding it" >&2
    fi
    parse_aide_config "$local_file" "_local"
    # Scalars: local wins
    [[ -n "$_local_docker" ]] && CONF_DOCKER="$_local_docker"
    [[ -n "$_local_kube"   ]] && CONF_KUBE="$_local_kube"
    # Lists: append
    CONF_EXTRA_DOMAINS="${CONF_EXTRA_DOMAINS:+$CONF_EXTRA_DOMAINS }${_local_extra_domains}"
    CONF_EXTRA_DOMAINS="${CONF_EXTRA_DOMAINS## }"  # trim leading space
  fi
}

# resolve_docker_socket <value>
# Resolves docker preset names to socket paths and validates.
resolve_docker_socket() {
  local val="$1"
  local sock
  case "$val" in
    rancher) sock="$HOME/.rd/docker.sock" ;;
    *)       sock="$val" ;;
  esac
  sock="${sock/#\~/$HOME}"
  if [[ ! -S "$sock" ]]; then
    die "--docker: socket not found or not a socket: $sock"
  fi
  echo "$sock"
}

# extract_kube_server <kubeconfig-path>
# Returns the server URL of the current-context cluster, or empty if kubectl is unavailable.
extract_kube_server() {
  local kube="$1"
  command -v kubectl &>/dev/null || return 0
  KUBECONFIG="$kube" kubectl config view --minify -o jsonpath='{.clusters[0].cluster.server}' 2>/dev/null || true
}

# is_local_server <server-url>
# Returns 0 (true) if the server URL points to localhost/127.0.0.1
is_local_server() {
  local url="$1"
  [[ "$url" =~ ^https?://(localhost|127\.0\.0\.1)(:[0-9]+)?(/.*)?$ ]]
}

# extract_port <server-url>
# Extracts port from URL; defaults to 443 if not present.
extract_port() {
  local url="$1"
  if [[ "$url" =~ :([0-9]+)(/|$) ]]; then
    echo "${BASH_REMATCH[1]}"
  else
    echo "443"
  fi
}

preflight() {
  if ! command -v docker &>/dev/null; then
    die "Docker is not installed or not in PATH"
  fi
  if ! docker info &>/dev/null 2>&1; then
    die "Docker daemon is not running"
  fi
}

image_exists() {
  docker image inspect "$IMAGE_NAME" &>/dev/null 2>&1
}

# ── Subcommands ──────────────────────────────────────────────────────────────

cmd_build() {
  local build_args=()

  # Auto-inject corporate CA cert: check certs/ dir, then AIDE_CA_CERT_FILE env
  local cert_file="${AIDE_CA_CERT_FILE:-}"
  if [[ -z "$cert_file" ]]; then
    # Use first cert found in certs/ directory
    for f in "$AIDE_ROOT"/certs/*.crt "$AIDE_ROOT"/certs/*.pem "$AIDE_ROOT"/certs/*.cer; do
      [[ -f "$f" ]] && { cert_file="$f"; break; }
    done
  fi
  if [[ -n "$cert_file" ]]; then
    echo "aide: injecting CA cert from $cert_file"
    build_args+=(--build-arg "EXTRA_CA_CERT_B64=$(base64 < "$cert_file" | tr -d '\n')")
  fi

  echo "aide: building image..."
  docker build -t "$IMAGE_NAME" ${build_args[@]+"${build_args[@]}"} "$AIDE_ROOT"
}

cmd_pull() {
  echo "aide: updating..."
  git -C "$AIDE_ROOT" pull --ff-only
  cmd_build
}

setup_docker_flags() {
  preflight

  if ! image_exists; then
    echo "aide: image not found, building first..."
    cmd_build
  fi

  # Read host git identity for use inside the container
  git_name=$(git config --global user.name 2>/dev/null || true)
  git_email=$(git config --global user.email 2>/dev/null || true)
  if [[ -z "$git_name" || -z "$git_email" ]]; then
    echo "aide: warning: host git user.name or user.email not set; commits inside container may use defaults" >&2
  fi

  docker_flags=(
    --rm
    --init
    --cap-add=NET_ADMIN
    --cap-add=NET_RAW
    -v "$PWD:/workspace"
    -v aide-claude:/home/aide/.claude
    -e ANTHROPIC_API_KEY
    -e "ANTHROPIC_BASE_URL=https://api.anthropic.com"
    -w /workspace
  )

  # Mount skills/ into ~/.claude/skills/ if the directory exists (rw so agent can persist new skills)
  if [[ -d "$AIDE_ROOT/skills" ]]; then
    docker_flags+=(-v "$AIDE_ROOT/skills:/home/aide/.claude/skills")
  fi

  # Mount commands/ into ~/.claude/commands/ if the directory exists (rw so agent can persist new commands)
  if [[ -d "$AIDE_ROOT/commands" ]]; then
    docker_flags+=(-v "$AIDE_ROOT/commands:/home/aide/.claude/commands")
  fi

  # Pass git identity as env vars
  if [[ -n "$git_name" ]]; then
    docker_flags+=(-e "GIT_AUTHOR_NAME=$git_name" -e "GIT_COMMITTER_NAME=$git_name")
  fi
  if [[ -n "$git_email" ]]; then
    docker_flags+=(-e "GIT_AUTHOR_EMAIL=$git_email" -e "GIT_COMMITTER_EMAIL=$git_email")
  fi

  # Merge extra_domains from config into AIDE_EXTRA_DOMAINS
  if [[ -n "${CONF_EXTRA_DOMAINS:-}" ]]; then
    export AIDE_EXTRA_DOMAINS="${AIDE_EXTRA_DOMAINS:+$AIDE_EXTRA_DOMAINS }$CONF_EXTRA_DOMAINS"
  fi

  # Docker socket passthrough
  # Priority: CLI --docker > aide.yaml docker > none
  local docker_val="${DOCKER_SOCKET_ARG:-${CONF_DOCKER:-}}"
  if [[ -n "$docker_val" ]]; then
    local docker_sock
    docker_sock=$(resolve_docker_socket "$docker_val")
    docker_flags+=(
      -v "$docker_sock:/var/run/docker.sock"
      -e "DOCKER_HOST=unix:///var/run/docker.sock"
    )
    echo "aide: mounting Docker socket: $docker_sock"
  fi

  # Kubeconfig passthrough
  # Priority: CLI --kube > aide.yaml kube > none
  local kube_val="${KUBE_ARG:-${CONF_KUBE:-}}"
  if [[ -n "$kube_val" ]]; then
    kube_val="${kube_val/#\~/$HOME}"
    [[ -f "$kube_val" ]] || die "--kube: file not found: $kube_val"

    local tmp_kube_dir
    tmp_kube_dir=$(mktemp -d "$HOME/.aide-kube-XXXXXX")

    # Detect local cluster → socat proxy on host + DNAT in container
    # (Rancher/k3s binds to 127.0.0.1 only; socat bridges it to the docker bridge IP)
    local server port
    server=$(extract_kube_server "$kube_val")
    if [[ -n "$server" ]] && is_local_server "$server"; then
      port=$(extract_port "$server")
      if ! command -v socat &>/dev/null; then
        echo "aide: warning: socat not found; local K8s cluster (${server}) not accessible — install socat" >&2
        cp "$kube_val" "$tmp_kube_dir/config"
      else
        local proxy_port kube_proxy_pid
        proxy_port=$(python3 -c 'import socket; s=socket.socket(); s.bind(("",0)); print(s.getsockname()[1]); s.close()')
        # Rewrite server URL directly into tmp dir (keeps 127.0.0.1 so TLS SANs still match)
        sed -E "s,https://(127\\.0\\.0\\.1|localhost):[0-9]+,https://127.0.0.1:${proxy_port},g" \
          "$kube_val" > "$tmp_kube_dir/config"
        socat "TCP-LISTEN:${proxy_port},bind=0.0.0.0,reuseaddr,fork" "TCP:127.0.0.1:${port}" &
        kube_proxy_pid=$!
        docker_flags+=(-e "AIDE_KUBE_LOCAL_PORT=$proxy_port")
        echo "aide: local K8s socat proxy active (:${proxy_port} → 127.0.0.1:${port}) — in-container proxy will forward via host.docker.internal"
      fi
    else
      cp "$kube_val" "$tmp_kube_dir/config"
    fi
    chmod 600 "$tmp_kube_dir/config"

    docker_flags+=(
      -v "$tmp_kube_dir:/home/aide/.kube:ro"
      -e "KUBECONFIG=/home/aide/.kube/config"
    )
    echo "aide: mounting kubeconfig: $kube_val"
  fi

  # Merge firewall-domains.local (gitignored) into AIDE_EXTRA_DOMAINS
  local local_domains_file="$AIDE_ROOT/firewall-domains.local.txt"
  if [[ -f "$local_domains_file" ]]; then
    local file_domains
    file_domains=$(grep -v '^\s*#' "$local_domains_file" | tr '\n' ' ' | xargs || true)
    if [[ -n "$file_domains" ]]; then
      export AIDE_EXTRA_DOMAINS="${AIDE_EXTRA_DOMAINS:+$AIDE_EXTRA_DOMAINS }$file_domains"
    fi
  fi

  # Pass through AIDE_EXTRA_DOMAINS if set
  if [[ -n "${AIDE_EXTRA_DOMAINS:-}" ]]; then
    docker_flags+=(-e AIDE_EXTRA_DOMAINS)
  fi

  # Forward SSH agent socket if available (key never enters container)
  # On macOS, Docker VMs (Docker Desktop, Rancher Desktop) cannot bind-mount
  # Unix domain sockets. Use socat to TCP-proxy via host.docker.internal.
  if [[ -n "${SSH_AUTH_SOCK:-}" && -S "$SSH_AUTH_SOCK" ]]; then
    if [[ "$(uname -s)" == "Darwin" ]]; then
      if ! command -v socat &>/dev/null; then
        echo "aide: warning: socat not found; SSH agent will not be forwarded (install socat)" >&2
      else
        local ssh_proxy_port
        ssh_proxy_port=$(python3 -c 'import socket; s=socket.socket(); s.bind(("",0)); print(s.getsockname()[1]); s.close()')
        socat TCP-LISTEN:"$ssh_proxy_port",bind=0.0.0.0,reuseaddr,fork UNIX-CONNECT:"$SSH_AUTH_SOCK" &
        SSH_PROXY_PID=$!
        docker_flags+=(-e "SSH_AGENT_PROXY_PORT=$ssh_proxy_port")
      fi
    else
      docker_flags+=(-v "$SSH_AUTH_SOCK:/tmp/ssh_agent.sock" -e "SSH_AUTH_SOCK=/tmp/ssh_agent.sock")
    fi
  fi

  # Pass host CWD name so the container statusline can show the real project name
  local project_name
  project_name=$(basename "$PWD")
  docker_flags+=(-e "AIDE_PROJECT_NAME=$project_name")

  # Single combined cleanup trap for all background proxies and temp files
  # (covers SSH proxy, kube proxy, and temp kubeconfig — whichever are active)
  trap "kill ${SSH_PROXY_PID:-} 2>/dev/null || true; kill ${kube_proxy_pid:-} 2>/dev/null || true${tmp_kube_dir:+; rm -rf '$tmp_kube_dir'}" EXIT
}

cmd_run() {
  local extra_mounts=()
  local extra_docker_flags=()
  local claude_args=()
  local noninteractive=false
  local caffeinate=false
  local dangerous=false
  local shell_mode=false
  local DOCKER_SOCKET_ARG=""
  local KUBE_ARG=""
  local CONFIG_ARG=""

  while [[ $# -gt 0 ]]; do
    case "$1" in
      shell)
        shell_mode=true
        shift
        break  # remaining args are an optional command to run inside the shell
        ;;
      --docker)
        if [[ -n "${2:-}" && "${2}" != --* ]]; then
          DOCKER_SOCKET_ARG="$2"; shift 2
        else
          DOCKER_SOCKET_ARG="rancher"; shift
        fi
        ;;
      --kube)
        [[ -z "${2:-}" ]] && die "--kube requires a path argument"
        KUBE_ARG="$2"; shift 2
        ;;
      --config)
        [[ -z "${2:-}" ]] && die "--config requires a path argument"
        CONFIG_ARG="$2"; shift 2
        ;;
      -m)
        [[ -z "${2:-}" ]] && die "-m requires a path argument"
        local src
        src=$(cd "$2" && pwd)
        local base
        base=$(basename "$src")
        extra_mounts+=(-v "$src:/extra/$base:ro")
        shift 2
        ;;
      -mw)
        [[ -z "${2:-}" ]] && die "-mw requires a path argument"
        local src_rw
        src_rw=$(cd "$2" && pwd)
        local base_rw
        base_rw=$(basename "$src_rw")
        extra_mounts+=(-v "$src_rw:/extra/$base_rw")
        shift 2
        ;;
      -p)
        [[ -z "${2:-}" ]] && die "-p requires a prompt argument"
        noninteractive=true
        claude_args+=(-p "$2")
        shift 2
        ;;
      --caffeinate|-c)
        caffeinate=true
        shift
        ;;
      --dangerous|-d)
        dangerous=true
        shift
        ;;
      --)
        shift
        extra_docker_flags+=("$@")
        break
        ;;
      -h|--help)
        usage
        exit 0
        ;;
      *)
        die "unknown argument: $1 (use -- to pass flags to docker run)"
        ;;
    esac
  done

  # Done parsing args; load config (CLI --config or CWD auto-discovery)
  load_project_config "${CONFIG_ARG:-}"

  local docker_flags=() git_name="" git_email=""
  setup_docker_flags

  # workaround for bash to not expand arrays with empty values
  docker_flags+=(${extra_mounts[@]+"${extra_mounts[@]}"})
  docker_flags+=(${extra_docker_flags[@]+"${extra_docker_flags[@]}"})

  if [[ "$shell_mode" == true ]]; then
    if [[ $# -gt 0 ]]; then
      # One-off command: run non-interactively
      docker run "${docker_flags[@]}" "$IMAGE_NAME" bash -c "$*"
    else
      docker_flags+=(-it)
      docker run "${docker_flags[@]}" "$IMAGE_NAME" bash
    fi
    return
  fi

  # Interactive TTY unless non-interactive mode
  if [[ "$noninteractive" == false ]]; then
    docker_flags+=(-it)
  fi

  # acceptEdits is default on; dangerous mode skips all permission prompts
  if [[ "$dangerous" == true ]]; then
    claude_args+=(--dangerously-skip-permissions)
  else
    claude_args+=(--permission-mode acceptEdits)
  fi

  local runner=()
  if [[ "$caffeinate" == true ]]; then
    if command -v caffeinate &>/dev/null; then
      runner=(caffeinate)
    else
      echo "aide: warning: caffeinate not found in PATH, ignoring --caffeinate" >&2
    fi
  fi

  "${runner[@]+"${runner[@]}"}" docker run "${docker_flags[@]}" "$IMAGE_NAME" claude ${claude_args[@]+"${claude_args[@]}"}
}

cmd_shell() {
  local DOCKER_SOCKET_ARG="" KUBE_ARG="" CONFIG_ARG=""
  load_project_config ""
  local docker_flags=() git_name="" git_email=""
  setup_docker_flags
  docker_flags+=(-it)
  docker run "${docker_flags[@]}" "$IMAGE_NAME" bash
}

# ── Main ─────────────────────────────────────────────────────────────────────

case "${1:-}" in
  build)
    cmd_build
    ;;
  pull)
    cmd_pull
    ;;
  shell)
    cmd_shell
    ;;
  -h|--help)
    usage
    ;;
  *)
    cmd_run "$@"
    ;;
esac
